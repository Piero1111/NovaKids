        </Component>
        <Component class="javax.swing.JLabel" name="jLabel3">
          <Properties>
            <Property name="text" type="java.lang.String" value="Es una empresa dedicada a la venta de juguetes para ni&#xf1;os, enfocada en brindar productos que combinan diversi&#xf3;n, creatividad y aprendizaje. "/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel2">
          <Properties>
            <Property name="text" type="java.lang.String" value="Nuestro objetivo es ofrecer una experiencia agradable para las familias, con juguetes de calidad que estimulen la imaginaci&#xf3;n y "/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel4">
          <Properties>
            <Property name="text" type="java.lang.String" value="contribuyan al desarrollo de los m&#xe1;s peque&#xf1;os."/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel5">
          <Properties>
            <Property name="text" type="java.lang.String" value="La misi&#xf3;n de NovaKids es ofrecer juguetes creativos, seguros y educativos que ayuden al desarrollo, aprendizaje y diversi&#xf3;n de los ni&#xf1;os, "/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel6">
          <Properties>
            <Property name="text" type="java.lang.String" value="brindando a las familias productos de calidad y una atenci&#xf3;n confiable."/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel7">
          <Properties>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Segoe UI Black" size="18" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="VISI&#xd3;N"/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel8">
          <Properties>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Segoe UI Black" size="18" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="MISI&#xd3;N"/>
