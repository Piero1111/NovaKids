        </Component>
        <Component class="javax.swing.JLabel" name="jLabel9">
          <Properties>
            <Property name="text" type="java.lang.String" value="Ser una empresa reconocida en la venta de juguetes infantiles, destacando por ofrecer productos innovadores, seguros y divertidos que  "/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel10">
          <Properties>
